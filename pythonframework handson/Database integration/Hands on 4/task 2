-- Task 2: Add Indexes and Compare Plans
-- =====================================================

-- Create index on enrollment_year
CREATE INDEX idx_students_enrollment_year
ON students(enrollment_year);

-- Create composite unique index
CREATE UNIQUE INDEX idx_enrollments_student_course
ON enrollments(student_id, course_id);

-- Create index on course_code
CREATE INDEX idx_courses_course_code
ON courses(course_code);

-- Run EXPLAIN again after creating indexes
EXPLAIN FORMAT=JSON
SELECT
    s.first_name,
    s.last_name,
    c.course_name
FROM enrollments e
JOIN students s
ON s.student_id = e.student_id
JOIN courses c
ON c.course_id = e.course_id
WHERE s.enrollment_year = 2022;

-- Create index on student_id
CREATE INDEX idx_enrollments_student
ON enrollments(student_id);
